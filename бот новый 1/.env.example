# Polymarket CLOB — бот торгует с баланса Polymarket, не с MetaMask
# POLY_FUNDER = адрес кошелька Polymarket (профиль, тот где лежат деньги в приложении). Тот же адрес что в URL профиля.
# POLY_PRIVATE_KEY = ключ, которым УПРАВЛЯЕТСЯ этот кошелёк. Если заходишь в Polymarket через email/Google — экспортируй ключ в настройках Polymarket (Settings → Export key), вставь сюда, и поставь POLY_SIGNATURE_TYPE=1. Не используй ключ от MetaMask, если аккаунт не привязан через MetaMask.
# POLY_SIGNATURE_TYPE: 0=EOA (MetaMask как основной кошелёк), 1=Polymarket email/Google кошелёк, 2=браузерный proxy (MetaMask подключён к Polymarket).
POLY_FUNDER="0x82a9b26808486259e55cb79d3d338f1ddc9be312"
POLY_PRIVATE_KEY="0x30a8f08c2a0a065022b82d020618ff5955fb43bceb67ac79bd2bdd145230c30d"
POLY_SIGNATURE_TYPE="1"

# Mode
DRY_RUN="0"
REQUIRE_ALLOWANCE="1"

# Market
MARKET_SLUG="auto"
MARKET_WINDOW="5m"

# Cooldowns / submission
AMBIGUOUS_COOLDOWN_SEC="90"
AMBIGUOUS_BALANCE_POLL_INTERVAL_SEC="15"
AMBIGUOUS_RECONCILE_FAST_POLLS="6"
AMBIGUOUS_RECONCILE_FAST_INTERVAL_SEC="2"
AMBIGUOUS_RECONCILE_SLOW_INTERVAL_SEC="5"
COOLDOWN_SEC="120"

# Order execution
WAIT_FILL_MS="1200"
POLL_FILL_MS="200"
MAKER_WAIT_MS="900"
MAKER_BUMP_BPS="0.8"
POST_BUY_EXIT_DELAY_SEC="2.5"
POST_BUY_WAIT_FOR_BALANCE_SEC="8"

# Entry
AGGRESSIVE_ENTRY="1"
AGGRESSION_FACTOR="1.0015"
USE_SMART_BUY="0"
ENTRY_STRICT_EXIT_VIABILITY="0"
ENTRY_MAX_SPREAD_BPS="150"
ENTRY_MIN_INTERVAL_SEC="2.5"
# Anti-noise: require momentum to hold for N ticks or T sec before entry
ENTRY_CONFIRMATION_TICKS="3"
ENTRY_CONFIRMATION_SEC="2.0"

# Risk
MAX_USD_PER_TRADE="4"
MAX_OPEN_TRADES="1"
MAX_ENTRIES_PER_WINDOW="1"
SESSION_LOSS_LIMIT_USD="5"
MAX_CONSEC_LOSSES="6"

# Liquidity
MIN_LIQ_USD="1.5"
EXIT_MIN_LIQ_USD="0.5"
MIN_ENTRY_PRICE="0.08"
MAX_ENTRY_PRICE="0.72"
MAX_BOOK_AGE_MS="1000"
L1_POLL_SEC="1.0"
# Book state: strict_valid (diagnostic) vs usable_l1 (trading); hysteresis; specific invalid reasons
BOOK_STALE_SIDE_SEC="30"
BOOK_SIDE_STALE_MS="30000"
BOOK_SATURATED_BID_THRESHOLD="0.99"
BOOK_SATURATED_ASK_THRESHOLD="0.01"
BOOK_USABLE_MAX_SPREAD_BPS="5000"
BOOK_STATE_LOG_INTERVAL_SEC="30"
# Hysteresis: invalid only after N bad updates in a row OR T ms of bad state
BOOK_INVALID_STREAK_THRESHOLD="3"
BOOK_INVALID_FOR_MS="400"
# Watchdog / recovery (heartbeat staleness)
BTC_FEED_STALE_SEC="8"
BOOK_FEED_STALE_SEC="8"
STRATEGY_STALE_SEC="12"
WSQ_STALL_SEC="15"
MARKET_RECOVERY_CONFIRM_SEC="10"
# Block new entries when WS drop rate above this (0.15 = 15%); exits still allowed
ENTRY_BLOCK_DROP_RATE="0.15"
# Decision loop: min ms between runs (throttle), debounce in code
DECISION_MIN_INTERVAL_MS="250"
# When 1: decisions only on timer (WS only updates book); interval below
DECISION_ON_TIMER_ONLY="0"
DECISION_TIMER_INTERVAL_SEC="1.0"
# Intervals: BAL poll / HEALTH print / BOOK_STATE summary (reduce load)
BAL_CACHE_TTL="30"
HEALTH_PRINT_INTERVAL_SEC="30"
BOOK_STATE_SUMMARY_INTERVAL_SEC="15"
# Book log: only log BOOK_STATE if bid/ask moved >= this (0.02 = no 0.01 ticks)
BOOK_STATE_MIN_DELTA_PX="0.02"
DEBUG_BOOK_VERBOSE="0"

# Fees
FEE_BPS="0"
FEE_BUFFER="0.0005"
FEE_BUFFER_BPS="3"

# Hold / exit — stateful exit pipeline (MIN_HOLD blocks weak exits; only emergency/hard_stop in first N sec)
HOLD_MAX_SEC="240"
MIN_HOLD_SEC="15"
TAKE_PROFIT_PCT="0.50"
STOP_LOSS_PCT="0.30"
FORCE_EXIT_NEAR_EXPIRY_SEC="30"
# Exit only from usable_l1; if book unusable longer than this ms, allow protective exit
EXIT_ON_UNUSABLE_BOOK_MS="15000"
# Exit hysteresis: weak reasons (trailing, thesis_broken, time_decay, TP exhaustion) require N consecutive ticks or T ms
EXIT_SIGNAL_STREAK_THRESHOLD="3"
EXIT_SIGNAL_FOR_MS="800"
# Hard stop: max loss pct (always applied, no hysteresis)
EXIT_HARD_STOP_PCT="0.12"
# Trailing from peak: arm when pnl >= this; giveback thresholds by peak band (small/medium/large peak => tighter/wider trailing)
EXIT_TRAILING_ARM_PCT="0.008"
EXIT_TRAILING_GIVEBACK_SMALL_PCT="0.005"
EXIT_TRAILING_GIVEBACK_MEDIUM_PCT="0.008"
EXIT_TRAILING_GIVEBACK_LARGE_PCT="0.012"
EXIT_TRAILING_PEAK_SMALL_PCT="0.015"
EXIT_TRAILING_PEAK_MEDIUM_PCT="0.025"
EXIT_TRAILING_PEAK_LARGE_PCT="0.04"
# Take profit: arm threshold; exhaustion = weak momentum / bid stale / low TTE
EXIT_TP_ARM_PCT="0.01"
# Adverse / thesis broken: min adverse delta from entry (pct), streak count, duration sec
EXIT_ADVERSE_MIN_DELTA_PCT="0.015"
EXIT_ADVERSE_STREAK_THRESHOLD="3"
EXIT_ADVERSE_DURATION_SEC="10"
EXIT_THESIS_BROKEN_STREAK="4"
# Time decay: TTE zones (early/mid/late/final) — stricter exit as TTE shrinks
EXIT_EARLY_TTE_SEC="200"
EXIT_MID_TTE_SEC="90"
EXIT_LATE_TTE_SEC="45"
EXIT_FINAL_TTE_SEC="25"
# Weak momentum (bps) for thesis/TP exhaustion
EXIT_WEAK_MOM_BPS="5"
# Exit eval log: interval in sec (avoid log spam)
EXIT_EVAL_LOG_INTERVAL_SEC="5"

# TTE / expiry
MIN_TIME_TO_EXPIRY_SEC="70"
MIN_ENTRY_TTE_SEC="70"
ENTRY_MIN_TTE_SEC="90"

# Strategy
MOM_LB_SEC="8"
MOM_THRESHOLD_PCT="0.0003"
DRIFT_LOOKBACK_SEC="8"
SIGMA_MIN="0.0005"
MIN_WARMUP_SEC="12"
VOL_LB_SEC="20"
K_DRIFT="0.25"
REGIME_TREND_MOM_BPS="1.5"
REGIME_CHOP_SPREAD_BPS="8"

# Exit execution
EXIT_MIN_SIZE="5"
EXIT_DUST_THRESHOLD="1"
EXIT_MIN_NOTIONAL_USD="1.5"
EXIT_MAX_BOOK_SHARE="0.3"
MAX_EXIT_RETRIES="2"
EXIT_MAX_SLICES="2"
EXIT_MAX_RECONCILE_RETRIES="3"
POSITION_DUST_EPS="0.0001"
EXIT_DUST_RECHECK_SEC="10"
EXIT_DUST_LOG_INTERVAL_SEC="30"
EXIT_SETTLEMENT_GRACE_SEC="2.0"
EXIT_WAIT_SETTLE_TIMEOUT_SEC="120"
EXIT_STUCK_TIMEOUT_SEC="60"
RECONCILE_MAX_MULTIPLIER="3.0"
OUTCOME_BALANCE_DECIMALS="6"
POST_LOSS_REENTRY_COOLDOWN_SEC="20"
EXIT_SLICE_DELAY_SEC="1.0"

# Same market
MAX_ENTRIES_PER_MARKET="1"
MAX_NOTIONAL_PER_MARKET_USD="4.0"
SAME_MARKET_REENTRY_MODE="until_new_slug"
SAME_MARKET_REENTRY_COOLDOWN_SEC="999999"
SAME_MARKET_GUARD_LOG_INTERVAL_SEC="30"

# L1 / 404
L1_404_GRACE_SEC="20"
L1_404_REQUIRED_CYCLES="5"

# Balance / rate limit
BAL_CACHE_TTL="20"
BALANCE_LOW_COOLDOWN_SEC="20"
BALANCE_LOW_WARN_INTERVAL_SEC="30"
L1_RATE_LIMIT_BACKOFF_SEC="30"
L1_RATE_LIMIT_BACKOFF_MAX_SEC="120"

# Debug / metrics
DEBUG_STRATEGY="1"
DEBUG_BAL_RAW="1"
ALLOW_WARN_ONCE="1"
PROM_ENABLED="0"
PROM_PORT="9108"
